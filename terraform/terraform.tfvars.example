# Copy to terraform.tfvars.
#
# Images (per service): precedence is digest > explicit *_image_tag > rolling_image_tag (default branch-main).
#
# Rolling deploy (always pull what CI last pushed to branch-main):
#   image_digest = ""
#   image_tag    = ""
#   rolling_image_tag = "branch-main"   # optional override if CI uses another moving tag
#
# Pin a build without digest (explicit immutable tag from CI, e.g. short SHA):
#   image_digest = ""
#   image_tag    = "f92d440"
#
# Pin exact bytes — rollback / audit (optional):
#   image_digest = "sha256:ed35e404d46758de087fcd76bbcbe64663a931f91f1f84fadadd06bbd57f7523"
#   image_tag    = ""

project_id            = "project-12f4b54b-d692-4583-83b"
project_number        = "684080887473"
region                = "asia-south1"
service_name          = "kdms-prod"
api_service_name      = "kdms-api-prod"
ar_repo               = "apps"
image_name            = "kdms-main"
image_digest          = ""
image_tag             = ""
rolling_image_tag     = "branch-main"
api_image_name        = "kdms-api"
api_image_digest      = ""
api_image_tag         = ""
runtime_sa_email      = "run-kdms@project-12f4b54b-d692-4583-83b.iam.gserviceaccount.com"
# Staging (example). For production Stream C: mysql-kdms-prod / kdms_prod / kdms_user — see docs/stream-c-db-switchover.md
cloudsql_instance     = "mysql-skm-prod"
db_name               = "kdms"
db_username           = "kdms"
min_instances         = 0
max_instances         = 5
cpu                   = "1"
memory                = "2Gi"
container_port        = 8080
container_concurrency = 80
ingress               = "INGRESS_TRAFFIC_ALL"
# cloud_run_deletion_protection = false # default; set true only to block accidental destroys (disable before removing services)
allow_unauthenticated = true
labels = {
  app = "kdms"
  env = "prod"
}
kdms_event_id = "2026"
app_url       = "https://kdms-prod-zeqw3ha4ya-el.a.run.app"
api_url       = "https://kdms-api-prod-zeqw3ha4ya-el.a.run.app"
secret_app_key     = "kdms-app-key"
secret_db_password = "kdms-db-password"
secret_service_key = "kdms-service-key"

api_min_instances         = 0
api_max_instances         = 10
api_cpu                   = "1"
api_memory                = "2Gi"
api_container_concurrency = 120
api_allow_unauthenticated = true

enable_reports_service         = true
reports_service_name           = "kdms-reports-prod"
reports_image_uri              = ""
reports_image_digest           = ""
reports_image_tag              = ""
reports_url                    = ""
reports_min_instances          = 0
reports_max_instances          = 4
reports_cpu                    = "1"
reports_memory                 = "2Gi"
reports_container_concurrency  = 40
reports_allow_unauthenticated  = true

enable_ocr_service         = false
# ocr_url removed Phase 6/7 — KDMS_OCR_BASE_URL no longer set on Cloud Run
ocr_image_uri              = ""
ocr_image_digest           = ""
ocr_image_tag              = ""
ocr_url                    = ""
ocr_min_instances          = 0
ocr_max_instances          = 6
ocr_cpu                    = "1"
ocr_memory                 = "2Gi"
ocr_container_port         = 5001
ocr_container_concurrency  = 20
ocr_allow_unauthenticated  = true

# kdms-registration (Phase 1.5) — day-visitor PWA
enable_registration_service         = false
registration_service_name           = "kdms-registration-prod"
registration_image_name             = "kdms-registration"
# Maps to KDMS_REGISTRATION_URL on kdms-api-prod (staffOcrExtract.php)
registration_url                    = "https://kdms-registration-prod-zeqw3ha4ya-el.a.run.app"
secret_registration_db_password     = "kdms-reg-db-password"
secret_document_ai_processor_id     = "document-ai-processor-id"
registration_db_username            = "kdms_reg"

# Optional: only if the connection name must differ from project_id:region:cloudsql_instance
# cloudsql_connection_name = "project-12f4b54b-d692-4583-83b:asia-south1:mysql-skm-prod"

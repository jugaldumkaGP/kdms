# Copy to .env for local development (e.g. docker compose --env-file .env).
# In Cloud Run, set these in the service or via Secret Manager references.

# --- Public URLs (recommended for container / cloud; optional for legacy XAMPP) ---
# WEBROOT_URL=https://your-run-url.run.app/
# API_BASE_URL=https://your-run-url.run.app/api/
# KDMS_OCR_BASE_URL=https://your-ocr-run-url.run.app
# Docker local (/kdms in URL): KDMS_INTERNAL_ORIGIN=http://127.0.0.1:8080/kdms
#
# Production Cloud Run: DocRoot=/var/www/kdms is served at URL root (no /kdms). Terraform sets
# WEBROOT_URL, API_BASE_URL, and KDMS_INTERNAL_ORIGIN so server-side curl hits
# http://127.0.0.1:8080/api/manageAdmin.php — not .../kdms/api/... (that path 404 on Cloud Run).
#
# If KDMS_APACHE_USE_PREFIX=1 and KDMS_INTERNAL_ORIGIN is unset, site_config defaults to loopback + /kdms.

# Event (non-secret; also set as Cloud Run env KDMS_EVENT_ID in prod)
KDMS_EVENT_ID=2025JB
KDMS_CHECK_ACCESS=true

# Path segment in URL (default kdms) when not using WEBROOT_URL
KDMS_PATH_SEGMENT=kdms

# DB (use KDMS_DB_SOCKET for Cloud SQL on Cloud Run, e.g. /cloudsql/PROJECT:REGION:INSTANCE)
# Native PHP on host: 127.0.0.1:3306. Docker Desktop (Mac/Win): use host so the container reaches MySQL on the host:
KDMS_DB_HOST=host.docker.internal:3306
# KDMS_DB_SOCKET=
KDMS_DB_NAME=kdms
KDMS_DB_INV_NAME=kinv2023
KDMS_DB_USER=kdms
KDMS_DB_PASSWORD=kdms

# 1=echo connection errors in HTML (dev only; never in prod)
KDMS_DB_DEBUG=0

# Timezone
PHP_TZ=Asia/Kolkata

# PHP memory: Docker/Cloud Run image sets memory_limit via docker/php/kdms-php.ini (e.g. search grid with many photos).
# Local XAMPP: raise memory_limit in php.ini if you hit "Allowed memory size exhausted" on devotee search.

# Force webroot to https in legacy mode (e.g. behind load balancer)
# KDMS_FORCE_HTTPS=0

# PHP sessions: database = shared MySQL table (kdms-main + kdms-api); cookie = default file handler.
SESSION_DRIVER=database
SESSION_LIFETIME=28800

# Shared key for trusted service-to-service and browser-to-API header auth (Option B migration).
# API endpoints accept X-KDMS-SERVICE-KEY and bypass session checks when this matches.
# KDMS_SERVICE_KEY=change-me
